# reaper-osc-actions.ini.snippet
#
# Append the single line below to <REAPER resource>/reaper-osc-actions.ini
# (create the file if it does not exist).
#
# Maps the multiplexed /rehearsaltools OSC address to the single custom action
# that dispatches every /rt/* operation based on the JSON payload's `command`
# field. See reaper-kb.ini.snippet for the SCR line that registers the action.

"/rehearsaltools" 0 0 _RS_rehearsaltools